		"@gramio/format": "^0.8.0",
		"@gramio/session": "^0.2.0",
		"@gramio/split": "^0.0.1",
		"@gramio/storage": "^2.0.1",
		"@openrouter/ai-sdk-provider": "^3.0.0",
		"@types/node": "^24.3.0",
		"ai": "^7.0.22",
		"gramio": "^0.12.0",
		"marked": "^15.0.11",
		"tsx": "^4.20.4",
		"typescript": "^5.9.2",
		"zod": "^4.4.3"
	},
	"peerDependencies": {
		"@gramio/format": ">=0.8.0",
		"@gramio/session": ">=0.2.0",
		"@gramio/storage": ">=2.0.0",
		"gramio": "^0.12.0",
		"marked": ">=12",
		"zod": ">=3.22",
		"ai": "^7.0.0",
		"@ai-sdk/anthropic": "^4.0.0",
		"@ai-sdk/openai-compatible": "^3.0.0",
		"@openrouter/ai-sdk-provider": "^3.0.0",
		"@gramio/split": "^0.0.1"
	},
	"peerDependenciesMeta": {
		"@gramio/format": {
			"optional": true
		},
		"@gramio/session": {
			"optional": true
		},
		"@gramio/storage": {
			"optional": true
		},
		"gramio": {
			"optional": true
		},
		"marked": {
			"optional": true
		},
		"zod": {
			"optional": true
		},
		"ai": {
			"optional": true
		},
		"@ai-sdk/anthropic": {
			"optional": true
		},
		"@ai-sdk/openai-compatible": {
			"optional": true
		},
		"@openrouter/ai-sdk-provider": {
			"optional": true
		},
		"@gramio/split": {
			"optional": true
		}
	},
	"publishConfig": {
		"access": "public",
		"registry": "https://registry.npmjs.org/"
