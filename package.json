	"files": [
		"dist"
	],
	"scripts": {
		"build": "tsc",
		"dev": "tsx src/index.ts",
		"test": "echo 'Tests not configured yet'",
		"test:runtime": "tsx tests/runtime-test.ts",
		"test:text": "tsx tests/text-test.ts",
		"test:browser": "open tests/browser-test.html",
		"example": "tsx tests/example.ts",
		"update-crypto": "tsx src/universal/currency/download-crypto-list.ts",
		"type-check": "tsc --noEmit",
		"lint": "biome lint",
		"format": "biome format",
		"check": "biome check",
		"fix": "biome check --write --unsafe",
		"ci": "biome ci",
		"prepublishOnly": "pnpm run build",
		"test:worker-safe": "pnpm run build && tsx tests/worker-safe-test.ts",
		"demo:bot": "tsx tests/create-demo.ts",
		"test:tg-html": "tsx tests/tg-html-test.ts",
		"test:flags": "tsx tests/flags-test.ts",
		"test:groups": "tsx tests/groups-test.ts",
		"test:user": "tsx tests/user-test.ts",
		"test:language-picker": "tsx tests/language-picker-test.ts",
		"test:llm": "tsx tests/llm-live-test.ts",
		"test:tg-md": "tsx tests/tg-md-test.ts"
	},
	"keywords": [
		"typescript",
		"utils",
		"log",
		"currency",
		"format"
	],
	"author": "Adrian Galilea <adriangalilea@gmail.com>",
	"license": "MIT",
