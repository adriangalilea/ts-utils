{
  "name": "@adriangalilea/utils",
  "version": "0.11.0",
  "description": "TypeScript utilities - logger, currency, formatter, GramIO bot plugins, and more",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "browser": "./dist/browser.js",
      "node": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./browser": {
      "types": "./dist/browser.d.ts",
      "default": "./dist/browser.js"
    },
    "./runtime": {
      "types": "./dist/runtime.d.ts",
      "default": "./dist/runtime.js"
    },
    "./format": {
      "types": "./dist/universal/format.d.ts",
      "default": "./dist/universal/format.js"
    },
    "./currency": {
      "types": "./dist/universal/currency/index.d.ts",
      "default": "./dist/universal/currency/index.js"
    },
    "./say": {
      "types": "./dist/say/index.d.ts",
      "default": "./dist/say/index.js"
    },
    "./bot": {
      "types": "./dist/bot/index.d.ts",
      "default": "./dist/bot/index.js"
    },
    "./bot/access-control": {
      "types": "./dist/bot/access-control.d.ts",
      "default": "./dist/bot/access-control.js"
    },
    "./bot/coalesce": {
      "types": "./dist/bot/coalesce.d.ts",
      "default": "./dist/bot/coalesce.js"
    },
    "./bot/language": {
      "types": "./dist/bot/language.d.ts",
      "default": "./dist/bot/language.js"
    },
    "./bot/menu": {
      "types": "./dist/bot/menu.d.ts",
      "default": "./dist/bot/menu.js"
    },
    "./bot/message-history": {
      "types": "./dist/bot/message-history.d.ts",
      "default": "./dist/bot/message-history.js"
    },
    "./bot/kit": {
      "types": "./dist/bot/kit.d.ts",
      "default": "./dist/bot/kit.js"
    },
    "./bot/llm-stream": {
      "types": "./dist/bot/llm-stream.d.ts",
      "default": "./dist/bot/llm-stream.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/index.ts",
    "test": "echo 'Tests not configured yet'",
    "test:runtime": "tsx tests/runtime-test.ts",
    "test:browser": "open tests/browser-test.html",
    "example": "tsx tests/example.ts",
    "update-crypto": "tsx src/universal/currency/download-crypto-list.ts",
    "type-check": "tsc --noEmit",
    "lint": "echo 'No linter configured yet'",
    "prepublishOnly": "pnpm run build"
  },
  "keywords": [
    "typescript",
    "utils",
    "log",
    "currency",
    "format"
  ],
  "author": "Adrian Galilea <adriangalilea@gmail.com>",
  "license": "MIT",
  "devDependencies": {
    "@gramio/format": "^0.8.0",
    "@gramio/session": "^0.2.0",
    "@gramio/storage": "^2.0.1",
    "@types/node": "^24.3.0",
    "gramio": "^0.10.0",
    "marked": "^15.0.11",
    "tsx": "^4.20.4",
    "typescript": "^5.9.2"
  },
  "dependencies": {
    "chalk": "^5.6.0"
  },
  "peerDependencies": {
    "@gramio/format": ">=0.8.0",
    "@gramio/session": ">=0.2.0",
    "@gramio/storage": ">=2.0.0",
    "gramio": ">=0.10.0",
    "marked": ">=12"
  },
  "peerDependenciesMeta": {
    "@gramio/format": {
      "optional": true
    },
    "@gramio/session": {
      "optional": true
    },
    "@gramio/storage": {
      "optional": true
    },
    "gramio": {
      "optional": true
    },
    "marked": {
      "optional": true
    }
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "pnpm": {
    "overrides": {
      "@gramio/contexts": "github:adriangalilea/contexts#fix/auto-thread-private-chat-threaded-mode"
    },
    "onlyBuiltDependencies": [
      "@gramio/contexts"
    ]
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/adriangalilea/ts-utils.git"
  },
  "bugs": {
    "url": "https://github.com/adriangalilea/ts-utils/issues"
  },
  "homepage": "https://github.com/adriangalilea/ts-utils#readme"
}